{
  "name": "gitina",
  "displayName": "gitina",
  "description": "Gitina automatically changes the editor interface color based on the current Git branch.",
  "publisher": "khechini mohamed",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.git",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitBranchColor.refresh",
        "title": "Gitina Color Branch: Refresh"
      },
      {
        "command": "gitBranchColor.addRule",
        "title": "Gitina Color Branch: Add Branch Color Rule"
      }
    ],
    "configuration": {
      "title": "Gitina Color Branch",
      "properties": {
        "gitBranchColor.rules": {
          "type": "array",
          "default": [
            {
              "pattern": "^main$",
              "color": "#444444"
            },
            {
              "pattern": "^develop$",
              "color": "#2ecc71"
            },
            {
              "pattern": "^feature/.*",
              "color": "#f1c40f"
            },
            {
              "pattern": "^hotfix/.*",
              "color": "#e74c3c"
            }
          ],
          "description": "Regex rules mapping git branches to colors"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
