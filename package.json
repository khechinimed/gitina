{
  "name": "gitina",
  "displayName": "Gitina - Git Branch Colorizer",
  "description": "Color your VS Code interface by Git branch automatically. Define regex rules, get instant visual alerts on sensitive branches (main, production), disable rules on the fly, and share your team's color profile via a single JSON file.",
  "publisher": "khechini mohamed",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "license": "MIT",
  "keywords": ["git", "branch", "colors", "github", "theme", "alerts"],
  "categories": [
    "Visualization",
    "Other"
  ],
  "markdown": "github",
  "activationEvents": [
    "workspaceContains:.git",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/khechinimed/gitina.git"
  },
  "homepage": "https://github.com/khechinimed/gitina#readme",
  "icon": "media/icon/gitina_icon_marketplace.png",
  "galleryBanner": {
    "color": "#1f2328",
    "theme": "dark"
  },
  "screenshots": [
    "media/screenshots/sidebar.png",
    "media/screenshots/status_bar_sensitive.png",
    "media/screenshots/cmd_shift_p.png"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitBranchColorSidebar",
          "title": "Gitina",
          "icon": "media/sidebar-view-icon.svg"
        }
      ]
    },
    "views": {
      "gitBranchColorSidebar": [
        {
          "id": "gitBranchColor.sidebarView",
          "name": "Overview",
          "contextualTitle": "Gitina",
          "icon": "media/sidebar-view-icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "gitBranchColor.refresh",
          "when": "view == gitBranchColor.sidebarView",
          "group": "navigation@1"
        },
        {
          "command": "gitBranchColor.addRule",
          "when": "view == gitBranchColor.sidebarView",
          "group": "navigation@1"
        },
        {
          "command": "gitBranchColor.removeRule",
          "when": "view == gitBranchColor.sidebarView",
          "group": "navigation@2"
        },
        {
          "command": "gitBranchColor.exportProfile",
          "when": "view == gitBranchColor.sidebarView",
          "group": "navigation@3"
        },
        {
          "command": "gitBranchColor.importProfile",
          "when": "view == gitBranchColor.sidebarView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "gitBranchColor.editRuleColor",
          "when": "view == gitBranchColor.sidebarView && viewItem == gitinaRuleEnabled",
          "group": "inline@1"
        },
        {
          "command": "gitBranchColor.editRuleColor",
          "when": "view == gitBranchColor.sidebarView && viewItem == gitinaRuleDisabled",
          "group": "inline@1"
        },
        {
          "command": "gitBranchColor.disableRule",
          "when": "view == gitBranchColor.sidebarView && viewItem == gitinaRuleEnabled",
          "group": "inline@2"
        },
        {
          "command": "gitBranchColor.enableRule",
          "when": "view == gitBranchColor.sidebarView && viewItem == gitinaRuleDisabled",
          "group": "inline@2"
        }
      ]
    },
    "commands": [
      {
        "command": "gitBranchColor.addRule",
        "title": "Git Branch Color: Add Rule",
        "icon": {
          "light": "media/commands/add-light.svg",
          "dark": "media/commands/add-dark.svg"
        }
      },
      {
        "command": "gitBranchColor.removeRule",
        "title": "Git Branch Color: Remove Rule",
        "icon": {
          "light": "media/commands/remove-light.svg",
          "dark": "media/commands/remove-dark.svg"
        }
      },
      {
        "command": "gitBranchColor.listRules",
        "title": "Git Branch Color: List Rules"
      },
      {
        "command": "gitBranchColor.refresh",
        "title": "Git Branch Color: Refresh",
        "icon": {
          "light": "media/commands/refresh-light.svg",
          "dark": "media/commands/refresh-dark.svg"
        }
      },
      {
        "command": "gitBranchColor.editRuleColor",
        "title": "Git Branch Color: Edit Rule Color",
        "icon": "$(edit)"
      },
      {
        "command": "gitBranchColor.manageSensitiveBranches",
        "title": "Git Branch Color: Manage Sensitive Branches",
        "icon": "$(shield)"
      },
      {
        "command": "gitBranchColor.disableRule",
        "title": "Disable rule",
        "icon": "$(eye-closed)"
      },
      {
        "command": "gitBranchColor.enableRule",
        "title": "Enable rule",
        "icon": "$(eye)"
      },
      {
        "command": "gitBranchColor.exportProfile",
        "title": "Git Branch Color: Export Team Profile",
        "icon": "$(export)"
      },
      {
        "command": "gitBranchColor.importProfile",
        "title": "Git Branch Color: Import Team Profile",
        "icon": {
          "light": "media/commands/import-light.svg",
          "dark": "media/commands/import-dark.svg"
        }
      }
    ],
    "configuration": {
      "title": "Gitina Color Branch",
      "properties": {
        "gitBranchColor.rules": {
          "type": "array",
          "default": [
            {
              "pattern": "^main$",
              "color": "#444444"
            },
            {
              "pattern": "^develop$",
              "color": "#2ecc71"
            },
            {
              "pattern": "^feature/.*",
              "color": "#f1c40f"
            },
            {
              "pattern": "^hotfix/.*",
              "color": "#e74c3c"
            }
          ],
          "description": "Regex rules mapping git branches to colors"
        },
        "gitBranchColor.statusBarIcon": {
          "type": "string",
          "default": "",
          "description": "Icon before branch name in status bar. Leave empty to show only the branch name. Supports codicons like $(git-branch), $(rocket) or emoji."
        },
        "gitBranchColor.statusBarTextThemeColor": {
          "type": "string",
          "default": "",
          "description": "Theme color token used for branch text in status bar (example: editor.foreground or statusBar.foreground). Leave empty to use the default status bar text color."
        },
        "gitBranchColor.sensitiveBranchesEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a visual warning alert when working on a sensitive branch (e.g. main, production, release)."
        },
        "gitBranchColor.sensitiveBranches": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["main", "production", "release"],
          "description": "List of branch name patterns (regex anchored to full name) considered sensitive. A warning alert will be shown in the status bar and sidebar."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
