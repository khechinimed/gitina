{
  "name": "gitina",
  "displayName": "gitina",
  "description": "Gitina automatically changes the editor interface color based on the current Git branch.",
  "publisher": "khechini mohamed",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.git",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "media/sidebar-icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitBranchColorSidebar",
          "title": "Gitina",
          "icon": "media/sidebar-icon.png"
        }
      ]
    },
    "views": {
      "gitBranchColorSidebar": [
        {
          "id": "gitBranchColor.sidebarView",
          "name": "Overview",
          "contextualTitle": "Gitina",
          "icon": "media/sidebar-icon.png"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "gitBranchColor.refresh",
          "when": "view == gitBranchColor.sidebarView",
          "group": "navigation@1"
        },
        {
          "command": "gitBranchColor.addRule",
          "when": "view == gitBranchColor.sidebarView",
          "group": "navigation@1"
        },
        {
          "command": "gitBranchColor.removeRule",
          "when": "view == gitBranchColor.sidebarView",
          "group": "navigation@2"
        }
      ]
    },
    "commands": [
      {
        "command": "gitBranchColor.addRule",
        "title": "Git Branch Color: Add Rule",
        "icon": {
          "light": "media/commands/add.svg",
          "dark": "media/commands/add.svg"
        }
      },
      {
        "command": "gitBranchColor.removeRule",
        "title": "Git Branch Color: Remove Rule",
        "icon": {
          "light": "media/commands/remove.svg",
          "dark": "media/commands/remove.svg"
        }
      },
      {
        "command": "gitBranchColor.listRules",
        "title": "Git Branch Color: List Rules"
      },
      {
        "command": "gitBranchColor.refresh",
        "title": "Git Branch Color: Refresh",
        "icon": {
          "light": "media/commands/refresh.svg",
          "dark": "media/commands/refresh.svg"
        }
      }
    ],
    "configuration": {
      "title": "Gitina Color Branch",
      "properties": {
        "gitBranchColor.rules": {
          "type": "array",
          "default": [
            {
              "pattern": "^main$",
              "color": "#444444"
            },
            {
              "pattern": "^develop$",
              "color": "#2ecc71"
            },
            {
              "pattern": "^feature/.*",
              "color": "#f1c40f"
            },
            {
              "pattern": "^hotfix/.*",
              "color": "#e74c3c"
            }
          ],
          "description": "Regex rules mapping git branches to colors"
        },
        "gitBranchColor.statusBarIcon": {
          "type": "string",
          "default": "",
          "description": "Icon before branch name in status bar. Leave empty to show only the branch name. Supports codicons like $(git-branch), $(rocket) or emoji."
        },
        "gitBranchColor.statusBarTextThemeColor": {
          "type": "string",
          "default": "",
          "description": "Theme color token used for branch text in status bar (example: editor.foreground or statusBar.foreground). Leave empty to use the default status bar text color."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
