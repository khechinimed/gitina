// Place your settings in this file to overwrite default and user settings.
{
	"files.exclude": {
		"out": false // set this to true to hide the "out" folder with the compiled JS files
	},
	"search.exclude": {
		"out": true // set this to false to include "out" folder in search results
	},
	// Turn off tsc task auto detection since we have the necessary tasks as npm scripts
	"js/ts.tsc.autoDetect": "off",
	"workbench.colorCustomizations": {
		"statusBar.background": "#130f40",
		"statusBar.noFolderBackground": "#130f40",
		"statusBar.foreground": "#ffffff",
		"statusBar.noFolderForeground": "#ffffff",
		"titleBar.activeBackground": "#130f40",
		"titleBar.inactiveBackground": "#130f40",
		"titleBar.activeForeground": "#ffffff",
		"titleBar.inactiveForeground": "#ffffffB3",
		"activityBar.background": "#130f40",
		"activityBar.foreground": "#ffffff",
		"activityBar.inactiveForeground": "#ffffffB3"
	},
	"gitBranchColor.sensitiveBranches": [
		"main",
		"release"
	]
}
